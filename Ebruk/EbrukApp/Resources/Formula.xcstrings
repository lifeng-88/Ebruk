    "onboarding.coins.subtitle": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "First recipe in each category is free. Others cost %lld–%lld coins based on difficulty. Daily check-in grants %lld coins. Apple IAP available."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "每分类首条配方免费。其余配方按难易与危险程度定价（%lld-%lld 金币），每日签到可领 %lld 金币，也支持 Apple 内购充值。"
          }
        }
      }
    },
    "onboarding.custom.title": {
      "extractionState": "manual",
