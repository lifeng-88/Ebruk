    "onboarding.welcome.subtitle": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "143+ DIY formulas across 13 categories including cleaners, soaps, and candles."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "143+ 条手工配方，涵盖清洁剂、手工皂、蜡烛等 13 个分类，随时查阅学习。"
          }
        }
      }
    },
    "onboarding.coins.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Unlock with Coins"
          }
        },
